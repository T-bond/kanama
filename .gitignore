/Library/
example_project/.godot/
example_project/addons/kanama/libkanama_bootstrap.*
example_project/addons/kanama/kanama_bootstrap.*
example_project/addons/kanama/kanama.jar
example_project/addons/kanama/kanama-scripts.jar
