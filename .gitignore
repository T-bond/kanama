build/
out/
bin/
dist/
site/
*.class

# --- Gradle ---
.gradle/
gradle-app.setting
!gradle-wrapper.jar
!gradle-wrapper.properties

# --- Kotlin / KSP ---
.kotlin/
__pycache__/

# --- jextract output ---
# Generated Panama bindings — regenerate from gdextension_interface.h
src/generated/

# --- CMake (bootstrap.c shim) ---
bootstrap/build/
bootstrap/cmake-build-*/
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile

# --- Native libraries ---
*.so
*.dylib
*.dll
*.a
*.lib
*.o
*.obj

# --- Godot extension API dump ---
# Pulled from a built Godot binary — not source. Regenerate via:
#   godot --dump-extension-api
gdextension/extension_api.json

# NOTE: gdextension/gdextension_interface.h IS tracked (vendored from the Godot
# source tree for the pinned baseline). It is a stable ABI input that
# buildNativeBootstrap needs to compile, so a fresh clone must contain it.
# On a Godot upgrade, run scripts/refresh_godot_api.sh to overwrite it, then
# commit the diff (the upgrade becomes explicit and reviewable).

